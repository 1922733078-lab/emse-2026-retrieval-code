# API keys for generation scripts. Copy to .env and fill in real values.
# Never commit .env or real keys.

KIMI_API_KEY=your_kimi_api_key_here
KIMI_BASE_URL=https://api.kimi.com/coding/v1

GPT_API_KEY=your_gpt_api_key_here
GPT_BASE_URL=https://api.openai.com/v1

DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

LONGCAT_API_KEY=your_longcat_api_key_here
LONGCAT_BASE_URL=https://api.longcat.chat/openai/v1
LONGCAT_TIMEOUT=300

MINIMAX_API_KEY=your_minimax_api_key_here
MINIMAX_BASE_URL=https://www.autodl.art/api/v1

# Safety cap for the whole experiment run (USD).
EXPERIMENT_MAX_USD=20
