{"task_id": "nimbla_l2_007", "level": "L2", "category": "adaptive_modification", "signature": "def solve(series: str, start: int, end: int) -> list[float]:", "prompt": "Implement solve(series, start, end). Parse the series, select entries with timestamps in [start, end], and return their min-max normalized values.", "visible_tests": ["assert len(solve('NIM|1:B3,2:B0,3:A3,4:D9,5:G1,6:D6', 2, 4)) == 3 and all(abs(a - b) < 1e-9 for a, b in zip(solve('NIM|1:B3,2:B0,3:A3,4:D9,5:G1,6:D6', 2, 4), [0.1944444444444444, 0.0, 1.0]))"], "hidden_tests": ["assert len(solve('NIM|1:A1,2:B2,3:C3,4:D4', 2, 3)) == 2 and all(abs(a - b) < 1e-9 for a, b in zip(solve('NIM|1:A1,2:B2,3:C3,4:D4', 2, 3), [0.0, 1.0]))", "assert solve('NIM|1:A1,2:B2,3:C3', 5, 10) == []", "assert len(solve('NIM|1:A1,2:A1,3:A1', 1, 3)) == 3 and all(abs(a - b) < 1e-9 for a, b in zip(solve('NIM|1:A1,2:A1,3:A1', 1, 3), [0.0, 0.0, 0.0]))", "assert len(solve('NIM|1:A0,2:G9', 1, 2)) == 2 and all(abs(a - b) < 1e-9 for a, b in zip(solve('NIM|1:A0,2:G9', 1, 2), [0.0, 1.0]))", "assert len(solve('NIM|10:A1,20:B2,30:C3', 15, 25)) == 1 and all(abs(a - b) < 1e-9 for a, b in zip(solve('NIM|10:A1,20:B2,30:C3', 15, 25), [0.0]))"], "gold_snippets": ["parse_nimbla_series", "select_nimbla_range", "normalize_nimbla"], "distractor_snippets": ["normalize_nimbla_minmax_inverted"], "reasoning_steps": 3, "reference_solution_path": "solutions/nimbla/nimbla_l2_007.py"}
